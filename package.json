{
  "name": "memorial-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cms:dev": "npm --prefix cms run develop",
    "cms:build": "npm --prefix cms run build",
    "cms:start": "npm --prefix cms run start",
    "cms:db:up": "docker compose up -d postgres",
    "cms:db:down": "docker compose stop postgres"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
